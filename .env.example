# =============================================================================
# AI English Coach — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# ---- Application ----
APP_NAME=ai-english-coach
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000
APP_HOST=0.0.0.0
SECRET_KEY=change-me-to-a-random-string

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_english_coach
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- Vector DB (Qdrant) ----
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=english_coach

# ---- Object Storage (MinIO / S3) ----
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=ai-english-coach
S3_REGION=us-east-1

# ---- OpenAI ----
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=tts-1-hd
OPENAI_WHISPER_MODEL=whisper-1

# ---- Anthropic (fallback LLM) ----
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# ---- Deepgram (streaming ASR) ----
DEEPGRAM_API_KEY=your-deepgram-key
DEEPGRAM_MODEL=nova-2

# ---- FPT.AI (Vietnamese TTS) ----
FPT_API_KEY=your-fpt-key
FPT_TTS_VOICE=linh_south

# ---- SMS / OTP (for authentication) ----
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-sid
TWILIO_AUTH_TOKEN=your-token
TWILIO_PHONE_NUMBER=+1234567890

# ---- Zalo OA (notifications) ----
ZALO_OA_APP_ID=your-app-id
ZALO_OA_APP_SECRET=your-secret
ZALO_OA_ACCESS_TOKEN=your-token

# ---- Payment (VNPay) ----
VNPAY_TMN_CODE=your-code
VNPAY_HASH_SECRET=your-secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3000/payment/return

# ---- Payment (MoMo) ----
MOMO_PARTNER_CODE=your-code
MOMO_ACCESS_KEY=your-key
MOMO_SECRET_KEY=your-secret

# ---- Monitoring ----
SENTRY_DSN=
POSTHOG_KEY=

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_APP_NAME=AI English Coach
